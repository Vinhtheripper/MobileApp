<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <!-- Gallery access: API 26-32 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <!-- Gallery access: API 33+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- Camera -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>

    <application
        android:name=".MposApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Mpos"
        tools:targetApi="35"
        android:windowOptOutEdgeToEdgeEnforcement="true">


        <!-- ===================== LAUNCHER ===================== -->
        <!-- SplashActivity is the true entry point -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Mpos.SplashBlue"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Welcome/onboarding screen shown before login -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Mpos.Fullscreen"
            android:screenOrientation="portrait"/>

        <!-- Login — topographic background theme -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.Mpos.Login"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".StaffDashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.Mpos"/>

        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.Mpos.Login"
            android:windowSoftInputMode="adjustResize"/>

        <activity
            android:name=".MainActivity"
            android:exported="false"/>

        <!-- ===================== PRODUCT ===================== -->
        <activity android:name=".product.ProductListActivity"/>
        <activity android:name=".product.ProductFormActivity"/>
        <activity android:name=".pos.PosActivity"/>
        <activity android:name=".product.CsvImportActivity"/>

        <!-- ===================== ORDER / CART ===================== -->
        <activity android:name=".order.CheckoutActivity"/>
        <activity android:name=".order.OrderListActivity"/>
        <activity android:name=".order.OrderDetailActivity"/>
        <activity android:name=".order.OrderCustomerInfoActivity"/>
        <activity android:name=".cart.CartActivity"/>
        <activity android:name=".receipt.ReceiptActivity"/>
        <activity android:name=".notification.NotificationActivity"/>

        <!-- ===================== CUSTOMER ===================== -->
        <activity android:name=".customer.CustomerListActivity"/>
        <activity android:name=".customer.CustomerFormActivity"/>
        <activity android:name=".customer.CustomerDetailActivity"/>

        <!-- ===================== INVENTORY ===================== -->
        <activity android:name=".inventory.InventoryActivity"/>
        <activity android:name=".inventory.StockAdjustmentActivity"/>
        <activity android:name=".inventory.InventoryHistoryActivity"/>

        <!-- ===================== SHIFT / REPORT ===================== -->
        <activity android:name=".shift.ShiftActivity"/>
        <activity android:name=".shift.ShiftReportActivity"/>
        <activity android:name=".report.ReportActivity"/>

        <!-- ===================== EMPLOYEE / ADMIN ===================== -->
        <activity android:name=".employee.AuditLogActivity"/>
        <activity android:name=".employee.ManageEmployeeActivity"/>
        <activity android:name=".employee.EmployeeDetailActivity"/>
        <activity android:name=".employee.EmployeeKpiActivity"/>

        <!-- ===================== SETTINGS / PROFILE ===================== -->
        <activity android:name=".settings.SettingsActivity"/>
        <activity android:name=".profile.ProfileActivity"/>
        <activity android:name=".ui.MoreActivity"/>

        <!-- ===================== SHOP ===================== -->
        <activity android:name=".shop.CreateShopActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".shop.ShopListActivity"/>

        <!-- ===================== MISC ===================== -->
        <activity android:name=".omnichannel.UnifiedInboxActivity"/>
        <activity android:name=".omnichannel.OmnichannelActivity"/>
        <activity android:name=".sync.SyncStatusActivity"/>

        <!-- ===================== AI CHAT ===================== -->
        <activity android:name=".ai.AiChatActivity"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ===================== LOGISTICS ===================== -->
        <activity android:name=".logistics.ShippingActivity"/>

        <!-- FileProvider for camera capture -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

    </application>
</manifest>
