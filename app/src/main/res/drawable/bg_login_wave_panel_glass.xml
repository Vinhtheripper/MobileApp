<?xml version="1.0" encoding="utf-8"?>
<!--
    Frosted glass wave panel for login bottom section
    White semi-transparent (alpha ~0.94) so topographic bg shows subtly through
    Rounded top corners (wave effect)
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- #F0FFFFFF = white with ~94% opacity — mờ nhẹ để thấy nền xuyên qua -->
    <solid android:color="#F0FFFFFF"/>
    <corners
        android:topLeftRadius="36dp"
        android:topRightRadius="36dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp"/>
</shape>
