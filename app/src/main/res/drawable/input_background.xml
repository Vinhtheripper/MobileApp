<?xml version="1.0" encoding="utf-8"?>
<!-- Modern input background — white bg, 1dp border, 12dp radius, focus highlight -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/surface"/>
            <corners android:radius="@dimen/radius_xs"/>
            <stroke android:width="1.5dp" android:color="@color/blue_primary"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/surface"/>
            <corners android:radius="@dimen/radius_xs"/>
            <stroke android:width="1dp" android:color="@color/border"/>
        </shape>
    </item>
</selector>
