<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Force light/warm theme even in dark mode — mPOS Pro is always light -->
    <style name="Base.Theme.Mpos" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorOnPrimary">@color/surface</item>
        <item name="colorSecondary">@color/cyan_accent</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/app_background</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
    </style>

    <style name="Theme.Mpos" parent="Base.Theme.Mpos" />
</resources>