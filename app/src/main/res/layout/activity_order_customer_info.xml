<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <!-- AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#1C2333"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="16dp">
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            android:src="@drawable/ic_back"/>
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thông tin khách hàng"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/btnSkip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            android:text="Bỏ qua"
            android:textColor="#93C5FD"
            android:textSize="14sp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Smart Paste Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white_12"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_paste"/>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="8dp"
                        android:text="Điền thông minh từ tin nhắn"
                        android:textColor="#1C2333"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_blue_summary"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:text="AI"
                        android:textColor="#1558B0"
                        android:textSize="11sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Dán tin nhắn đặt hàng của khách vào đây, hệ thống sẽ tự nhận diện tên, SĐT và địa chỉ"
                    android:textColor="#64748B"
                    android:textSize="12sp"/>

                <EditText
                    android:id="@+id/inputSmartPaste"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="top|start"
                    android:hint="VD: Mình tên Nguyễn Văn A, SĐT 0901234567, giao về 123 Nguyễn Huệ Q1 TP.HCM..."
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"
                    android:textSize="13sp"/>

                <LinearLayout
                    android:id="@+id/btnAutoFill"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_pos_cat_active"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_auto_fill"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="Tự động điền"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E2E8F0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginStart="12dp" android:layout_marginEnd="12dp"
                    android:text="HOẶC ĐIỀN THỦ CÔNG"
                    android:textColor="#94A3B8" android:textSize="10sp" android:textStyle="bold"
                    android:letterSpacing="0.08"/>
                <View android:layout_width="0dp" android:layout_height="1dp"
                    android:layout_weight="1" android:background="#E2E8F0"/>
            </LinearLayout>

            <!-- Manual Fields Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white_12"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Name -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên khách"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_person" android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/inputCustomerName"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Nguyễn Văn A"
                        android:inputType="textPersonName|textCapWords"
                        android:singleLine="true"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Phone -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Số điện thoại"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_phone" android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/inputCustomerPhone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="0901 234 567"
                        android:inputType="phone"
                        android:singleLine="true"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Địa chỉ giao hàng"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="top"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="12dp"
                    android:paddingBottom="12dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_marginTop="2dp"
                        android:src="@drawable/ic_location" android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/inputCustomerAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Số nhà, đường, phường/xã, quận/huyện, tỉnh/thành"
                        android:inputType="textPostalAddress|textMultiLine"
                        android:minLines="2"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Note -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Ghi chú đơn hàng"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
                <EditText
                    android:id="@+id/inputOrderNote"
                    android:layout_width="match_parent"
                    android:layout_height="70dp"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="top|start"
                    android:hint="Giao giờ hành chính, gọi trước khi giao..."
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Existing customer lookup -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_white_12"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tìm khách hàng đã có"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_pos_search"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:src="@drawable/ic_search" android:tint="#94A3B8"/>
                    <EditText
                        android:id="@+id/inputSearchExistingCustomer"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Tìm theo tên hoặc SĐT..."
                        android:inputType="text"
                        android:singleLine="true"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                    <LinearLayout
                        android:id="@+id/btnLookupCustomer"
                        android:layout_width="40dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_blue"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:layout_marginEnd="4dp">
                        <ImageView android:layout_width="18dp" android:layout_height="18dp"
                            android:src="@drawable/ic_search"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Lookup result -->
                <LinearLayout
                    android:id="@+id/layoutCustomerResult"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_blue_summary"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:visibility="gone">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_circle_blue"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/txtResultInitials"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:orientation="vertical">
                        <TextView
                            android:id="@+id/txtResultName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#1C2333"
                            android:textSize="13sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/txtResultPhone"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#64748B"
                            android:textSize="12sp"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dùng"
                        android:textColor="#1558B0"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="16dp"/>
        </LinearLayout>
    </ScrollView>

    <!-- Bottom CTA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="16dp">
        <LinearLayout
            android:id="@+id/btnProceedCheckout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_pos_cat_active"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">
            <ImageView android:layout_width="20dp" android:layout_height="20dp"
                android:src="@drawable/ic_cart"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Tiến hành thanh toán"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
