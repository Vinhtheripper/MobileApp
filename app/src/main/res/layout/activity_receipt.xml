<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ══ SUCCESS HERO ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#1C2333"
            android:gravity="center"
            android:orientation="vertical">

            <!-- Checkmark circle -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_success_circle"
                android:scaleType="fitCenter"
                android:contentDescription="Thanh toán thành công"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Thanh toán thành công!"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtReceiptOrderCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#8AADD4"
                android:textSize="13sp"/>

            <!-- Amount badge -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_pos_cat_active"
                android:gravity="center"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <TextView
                    android:id="@+id/txtHeroAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ RECEIPT CARD (floats over hero) ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_surface"
            android:elevation="6dp"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Store name + address -->
            <TextView
                android:id="@+id/txtStoreName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Quầy mPOS Pro"
                android:textColor="#1C2333"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/txtStoreAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:gravity="center"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:visibility="gone"/>

            <!-- Date + cashier row -->
            <TextView
                android:id="@+id/txtReceiptDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center"
                android:textColor="#94A3B8"
                android:textSize="11sp"/>

            <!-- Dashed divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="10dp"
                android:background="#E2E8F0"/>

            <!-- Items list -->
            <LinearLayout
                android:id="@+id/layoutReceiptItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

            <!-- Totals divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="#E2E8F0"/>

            <!-- Subtotal row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tạm tính"
                    android:textColor="#64748B"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/txtReceiptSubtotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1C2333"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- VAT row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thuế VAT"
                    android:textColor="#64748B"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/txtReceiptVat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1C2333"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Payment method row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Thanh toán"
                    android:textColor="#64748B"
                    android:textSize="13sp"/>
                <TextView
                    android:id="@+id/txtReceiptPayMethod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#2875FB"
                    android:textSize="13sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Customer row -->
            <TextView
                android:id="@+id/txtReceiptCustomer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:visibility="gone"/>

            <!-- Total block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_receipt_total"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tổng thanh toán"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtReceiptTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Cash breakdown (CASH only) -->
            <LinearLayout
                android:id="@+id/layoutCashBreakdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_blue_summary"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tiền khách đưa"
                        android:textColor="#475569"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/txtReceiptReceived"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#1C2333"
                        android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tiền thừa trả khách"
                        android:textColor="#475569"
                        android:textSize="12sp"/>
                    <TextView
                        android:id="@+id/txtReceiptChange"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="#10B981"
                        android:textSize="12sp"
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>

        <!-- ══ SHARE ROW ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/card_surface"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp"
                android:text="Chia sẻ hóa đơn"
                android:textColor="#64748B"
                android:textSize="12sp"
                android:gravity="center"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <!-- Zalo -->
                <LinearLayout
                    android:id="@+id/btnShareZalo"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="@drawable/bg_zalo_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Z"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Zalo"
                        android:textColor="#475569"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Messenger -->
                <LinearLayout
                    android:id="@+id/btnShareMessenger"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="@drawable/bg_messenger_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="M"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Messenger"
                        android:textColor="#475569"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Bluetooth -->
                <LinearLayout
                    android:id="@+id/btnShareBluetooth"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="@drawable/bg_bluetooth_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BT"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Bluetooth"
                        android:textColor="#475569"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!-- Email PDF -->
                <LinearLayout
                    android:id="@+id/btnShareEmail"
                    android:layout_width="64dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp">
                    <LinearLayout
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:gravity="center"
                        android:background="@drawable/bg_email_circle">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Email PDF"
                        android:textColor="#475569"
                        android:textSize="11sp"/>
                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

        <!-- ══ ACTION BUTTONS ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnPrint"
                style="@style/Widget.Mpos.Button.Outline"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="In biên lai"/>

            <Button
                android:id="@+id/btnShare"
                style="@style/Widget.Mpos.Button.Outline"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Chia sẻ khác"/>

        </LinearLayout>

        <!-- ══ NEW SALE BUTTON ══ -->
        <Button
            android:id="@+id/btnNewSale"
            style="@style/Widget.Mpos.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:text="Đơn hàng mới"/>

    </LinearLayout>
</ScrollView>
