<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- Topographic background image -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_login_topo"
        android:scaleType="centerCrop"
        android:contentDescription="@null"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP: Blue section with back button + mascot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.30"
            android:orientation="vertical">

            <!-- Back button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:paddingStart="8dp">
                <Button
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:minWidth="0dp"
                    android:stateListAnimator="@null"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"/>
            </LinearLayout>

            <!-- Mascot + heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="12dp">

                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_logo_bg"
                    android:scaleType="fitCenter"
                    android:contentDescription="Quầy"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Tạo cửa hàng của bạn"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Bắt đầu bán hàng đa kênh miễn phí"
                    android:textColor="#93B4EF"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- BOTTOM: White card with form -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.70"
            android:background="@drawable/bg_login_wave_panel_glass"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng ký"
                    android:textColor="#1C2333"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điền thông tin để tạo tài khoản cửa hàng"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginBottom="20dp"/>

                <!-- Họ và tên -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Họ và tên" android:textColor="#374151" android:textSize="13sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="14dp">
                    <EditText android:id="@+id/inputFullName"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input_register"
                        android:hint="Nguyễn Văn A"
                        android:inputType="textPersonName"
                        android:paddingStart="44dp" android:paddingEnd="16dp"
                        android:textColor="#0F172A" android:textColorHint="#9CA3AF" android:textSize="14sp"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical" android:layout_marginStart="13dp"
                        android:src="@drawable/ic_person" android:tint="#9CA3AF"/>
                </FrameLayout>

                <!-- Số điện thoại -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Số điện thoại" android:textColor="#374151" android:textSize="13sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="14dp">
                    <EditText android:id="@+id/inputPhone"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input_register"
                        android:hint="09xx xxx xxx"
                        android:inputType="phone"
                        android:paddingStart="44dp" android:paddingEnd="16dp"
                        android:textColor="#0F172A" android:textColorHint="#9CA3AF" android:textSize="14sp"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical" android:layout_marginStart="13dp"
                        android:src="@drawable/ic_phone" android:tint="#9CA3AF"/>
                </FrameLayout>

                <!-- Email -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Email" android:textColor="#374151" android:textSize="13sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="14dp">
                    <EditText android:id="@+id/inputEmail"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input_register"
                        android:hint="you@cuahang.com"
                        android:inputType="textEmailAddress"
                        android:paddingStart="44dp" android:paddingEnd="16dp"
                        android:textColor="#0F172A" android:textColorHint="#9CA3AF" android:textSize="14sp"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical" android:layout_marginStart="13dp"
                        android:src="@drawable/ic_email" android:tint="#9CA3AF"/>
                </FrameLayout>

                <!-- Mật khẩu -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Mật khẩu" android:textColor="#374151" android:textSize="13sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="14dp">
                    <EditText android:id="@+id/inputPassword"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input_register"
                        android:hint="Nhập mật khẩu"
                        android:inputType="textPassword"
                        android:paddingStart="44dp" android:paddingEnd="48dp"
                        android:textColor="#0F172A" android:textColorHint="#9CA3AF" android:textSize="14sp"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical" android:layout_marginStart="13dp"
                        android:src="@drawable/ic_lock" android:tint="#9CA3AF"/>
                    <TextView android:id="@+id/btnTogglePassword"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:layout_gravity="end|center_vertical" android:layout_marginEnd="2dp"
                        android:clickable="true" android:focusable="true"
                        android:gravity="center" android:text="👁"
                        android:textColor="#9CA3AF" android:textSize="16sp"/>
                </FrameLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tối thiểu 6 ký tự"
                    android:textColor="#94A3B8" android:textSize="11sp"
                    android:layout_marginTop="-10dp" android:layout_marginBottom="10dp"/>

                <!-- Xác nhận mật khẩu -->
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Xác nhận mật khẩu" android:textColor="#374151" android:textSize="13sp"
                    android:textStyle="bold" android:layout_marginBottom="6dp"/>
                <FrameLayout android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginBottom="16dp">
                    <EditText android:id="@+id/inputConfirmPassword"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:background="@drawable/bg_input_register"
                        android:hint="Nhập lại mật khẩu"
                        android:inputType="textPassword"
                        android:paddingStart="44dp" android:paddingEnd="48dp"
                        android:textColor="#0F172A" android:textColorHint="#9CA3AF" android:textSize="14sp"/>
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:layout_gravity="start|center_vertical" android:layout_marginStart="13dp"
                        android:src="@drawable/ic_lock" android:tint="#9CA3AF"/>
                    <TextView android:id="@+id/btnToggleConfirmPassword"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:layout_gravity="end|center_vertical" android:layout_marginEnd="2dp"
                        android:clickable="true" android:focusable="true"
                        android:gravity="center" android:text="👁"
                        android:textColor="#9CA3AF" android:textSize="16sp"/>
                </FrameLayout>

                <!-- Terms checkbox -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">
                    <FrameLayout android:id="@+id/checkTermsContainer"
                        android:layout_width="22dp" android:layout_height="22dp"
                        android:background="@drawable/bg_checkbox_unchecked"
                        android:clickable="true" android:focusable="true">
                        <TextView android:id="@+id/checkTermsMark"
                            android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:text="✓"
                            android:textColor="#FFFFFF" android:textSize="12sp"
                            android:textStyle="bold" android:visibility="gone"/>
                    </FrameLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_marginStart="10dp" android:layout_weight="1"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Tôi đồng ý với " android:textColor="#64748B" android:textSize="13sp"/>
                        <TextView android:id="@+id/btnTermsLink"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:clickable="true" android:focusable="true"
                            android:text="Điều khoản" android:textColor="#2875FB"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" &amp; " android:textColor="#64748B" android:textSize="13sp"/>
                        <TextView android:id="@+id/btnPrivacyLink"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:clickable="true" android:focusable="true"
                            android:text="Chính sách" android:textColor="#2875FB"
                            android:textSize="13sp" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text=" của Quầy" android:textColor="#64748B" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Error -->
                <TextView android:id="@+id/txtRegisterError"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/badge_error"
                    android:padding="12dp"
                    android:textColor="@color/status_error"
                    android:visibility="gone"/>

                <!-- Register button -->
                <Button android:id="@+id/btnRegister"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:background="@drawable/bg_register_btn"
                    android:elevation="4dp"
                    android:stateListAnimator="@null"
                    android:text="Tạo tài khoản"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <!-- Divider -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:layout_marginTop="18dp" android:layout_marginBottom="14dp"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#DDE3EE"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginHorizontal="12dp" android:text="hoặc"
                        android:textColor="#94A3B8" android:textSize="12sp"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#DDE3EE"/>
                </LinearLayout>

                <!-- Google signup -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="50dp"
                    android:background="@drawable/bg_btn_google"
                    android:gravity="center" android:orientation="horizontal">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:layout_marginEnd="10dp" android:src="@drawable/ic_google" android:scaleType="fitCenter"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đăng ký bằng Google"
                        android:textColor="#3C4043" android:textSize="14sp" android:textStyle="bold"/>
                </LinearLayout>

                <!-- Login link -->
                <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal" android:layout_marginTop="18dp"
                    android:gravity="center" android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đã có cửa hàng? " android:textColor="#64748B" android:textSize="13sp"/>
                    <TextView android:id="@+id/btnGoToLogin"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Đăng nhập"
                        android:textColor="#2875FB" android:textSize="13sp" android:textStyle="bold"
                        android:clickable="true" android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
