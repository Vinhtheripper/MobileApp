<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚚 GHN (Giao Hàng Nhanh)"
            android:textColor="#1F2937"
            android:textSize="13sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/etGhnToken"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:hint="Shop Token GHN"
            android:textSize="13sp"/>
        <EditText
            android:id="@+id/etGhnShop"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="4dp"
            android:hint="Shop ID GHN"
            android:inputType="number"
            android:textSize="13sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E5E7EB"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📦 GHTK (Giao Hàng Tiết Kiệm)"
            android:textColor="#1F2937"
            android:textSize="13sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/etGhtkToken"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:hint="API Token GHTK"
            android:textSize="13sp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#E5E7EB"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📮 ViettelPost"
            android:textColor="#1F2937"
            android:textSize="13sp"
            android:textStyle="bold"/>
        <EditText
            android:id="@+id/etVtpToken"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:hint="Access Token ViettelPost"
            android:textSize="13sp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Token được lưu trên thiết bị. Đăng ký tại:\n• GHN: ghn.vn/shop\n• GHTK: sso.giaohangtietkiem.vn\n• VTP: partner.viettelpost.vn"
            android:textColor="#9CA3AF"
            android:textSize="11sp"/>
    </LinearLayout>
</ScrollView>
