<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="250dp"
    android:background="@drawable/bg_card_white_16"
    android:clipToOutline="true"
    android:elevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Image / Placeholder area -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#F3F4F6">

            <!-- Initials placeholder -->
            <TextView
                android:id="@+id/txtProductMark"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="#9CA3AF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <!-- Actual product image -->
            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"/>

            <!-- Stock status badge (top-left) -->
            <LinearLayout
                android:id="@+id/stockBadge"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_gravity="top|start"
                android:layout_margin="8dp"
                android:background="@drawable/bg_stock_in"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">

                <TextView
                    android:id="@+id/stockBadgeDot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="●"
                    android:textColor="#22C55E"
                    android:textSize="8sp"/>

                <TextView
                    android:id="@+id/stockBadgeText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Còn hàng"
                    android:textColor="#15803D"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Out-of-stock overlay -->
            <FrameLayout
                android:id="@+id/outOfStockOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#19000000"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_stock_out_pill"
                    android:paddingStart="12dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="12dp"
                    android:paddingBottom="4dp"
                    android:text="Hết hàng"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>
            </FrameLayout>
        </FrameLayout>

        <!-- Info area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#1C2333"
                android:textSize="14sp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="32dp"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txtProductPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#1A73E8"
                    android:textSize="14sp"/>

                <TextView
                    android:id="@+id/btnAddProduct"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_blue"
                    android:clickable="false"
                    android:focusable="false"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>