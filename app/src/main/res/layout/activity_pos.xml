<?xml version="1.0" encoding="utf-8"?>
<!--
    POS SCREEN — Quầy mPOS Pro
    Design: white AppBar, search + scan row, category chips, RecyclerView product grid.
    No emoji icons. No dark AppBar.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Space reserved for fixed AppBar -->
        <View
            android:layout_width="match_parent"
            android:layout_height="56dp"/>

        <!-- Search Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_pos_search"
                android:elevation="1dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:gravity="center"
                    android:text="🔍"
                    android:textSize="13sp"/>

                <EditText
                    android:id="@+id/inputSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Tìm kiếm sản phẩm hoặc SKU..."
                    android:inputType="text"
                    android:paddingStart="12dp"
                    android:paddingEnd="4dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#5F6368"
                    android:textSize="14sp"/>

                <LinearLayout
                    android:id="@+id/btnScan"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_pos_barcode_btn"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📷"
                        android:textSize="16sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Category Tabs -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:paddingStart="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/layoutCategories"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

        <!-- Product Grid -->
        <GridView
            android:id="@+id/gridProducts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:horizontalSpacing="8dp"
            android:numColumns="2"
            android:padding="16dp"
            android:paddingBottom="80dp"
            android:stretchMode="columnWidth"
            android:verticalSpacing="12dp"/>
    </LinearLayout>

    <!-- Fixed AppBar (overlays top) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="top"
        android:background="#1C2333"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:gravity="center"
            android:text="☰"
            android:textColor="#FFFFFF"
            android:textSize="16sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="POS — Bán hàng"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <!-- Cart button with badge (AppBar) -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp">

            <TextView
                android:id="@+id/btnCheckout"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="🛒"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/txtCartBadge"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:background="@drawable/badge_error"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- More button -->
        <TextView
            android:layout_width="36dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="⋮"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>
    </LinearLayout>

    <!-- Floating Cart FAB -->
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="80dp">

        <FrameLayout
            android:id="@+id/btnCartFab"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:background="@drawable/bg_circle_blue"
            android:clickable="true"
            android:elevation="6dp"
            android:focusable="true"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🛒"
                android:textSize="20sp"/>
        </FrameLayout>

        <TextView
            android:id="@+id/txtFabBadge"
            android:layout_width="20dp"
            android:layout_height="22dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="-4dp"
            android:layout_marginEnd="-4dp"
            android:background="@drawable/bg_pos_fab_badge"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="9sp"
            android:textStyle="bold"
            android:visibility="gone"/>
    </FrameLayout>

    <!-- Bottom Navigation (POS active) -->
    <include
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav_pos"/>

</FrameLayout>