<?xml version="1.0" encoding="utf-8"?>
<!--
    UNIFIED INBOX — Quầy mPOS Pro
    Grouped channel inbox: POS, Facebook, Shopee, Web.
    Filter chip row + RecyclerView messages.
    Built from 3-line stub.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ WHITE APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hộp thư"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtUnreadCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tất cả kênh bán hàng"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>

            <!-- Compose / New message -->
            <ImageView
                android:id="@+id/btnCompose"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_edit"
                android:tint="@color/blue_primary"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Soạn tin nhắn"/>
        </LinearLayout>

        <!-- ══ SEARCH ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/surface"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@drawable/bg_pos_search">
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="start|center_vertical"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_muted"
                    android:scaleType="center"
                    android:padding="10dp"/>
                <EditText
                    android:id="@+id/inputSearch"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:hint="Tìm đơn hàng, khách hàng..."
                    android:paddingStart="40dp"
                    android:paddingEnd="12dp"
                    android:singleLine="true"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_muted"
                    android:textSize="14sp"/>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ CHANNEL FILTER CHIPS ══ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/surface"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipAll"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat_active"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Tất cả"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipPos"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Tại quầy"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipFacebook"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Facebook"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipShopee"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Shopee"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>

                <TextView
                    android:id="@+id/chipWeb"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:text="Website"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"/>

        <!-- ══ INBOX LIST ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listInbox"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:overScrollMode="never"/>

        <!-- Empty state — shown when no messages -->
        <LinearLayout
            android:id="@+id/layoutEmpty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_mascot"
                android:scaleType="fitCenter"
                android:alpha="0.5"
                android:contentDescription="Hộp thư trống"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Hộp thư đang trống"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Đơn hàng từ tất cả kênh sẽ xuất hiện ở đây"
                android:textColor="@color/text_muted"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- Preserved legacy id for backward compat -->
        <TextView
            android:id="@+id/txtInbox"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:visibility="gone"/>

    </LinearLayout>
</FrameLayout>
