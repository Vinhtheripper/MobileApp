<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1C2333"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:id="@+id/txtFormTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Thông tin sản phẩm"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Image Upload Card (dashed border) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_image_dashed"
                    android:gravity="center"
                    android:minHeight="140dp"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <FrameLayout android:layout_width="80dp" android:layout_height="80dp">
                        <TextView
                            android:id="@+id/txtImgInitials"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_blue_summary"
                            android:gravity="center"
                            android:textColor="#1558B0"
                            android:textSize="24sp"
                            android:textStyle="bold"/>
                        <ImageView
                            android:id="@+id/imgPreview"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:scaleType="centerCrop"
                            android:visibility="gone"
                            android:background="@drawable/bg_card_white_12"/>
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Nhấn để thêm ảnh sản phẩm"
                        android:textColor="#64748B"
                        android:textSize="13sp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/btnPickGallery"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_card_white_12"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="🖼 Thư viện" android:textColor="#44474E" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/btnPickCamera"
                            android:layout_width="0dp"
                            android:layout_height="38dp"
                            android:layout_weight="1"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_card_white_12"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="📷 Camera" android:textColor="#44474E" android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnRemoveImage"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="Xoá ảnh"
                        android:textColor="#EF4444"
                        android:textSize="13sp"
                        android:visibility="gone"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <!-- Basic Info -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="THÔNG TIN CƠ BẢN"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/inputProductName"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Tên sản phẩm *"
                        android:inputType="textCapWords"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>

                    <EditText
                        android:id="@+id/inputSku"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="SKU *"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>

                    <EditText
                        android:id="@+id/inputBarcode"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Barcode (tùy chọn)"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>
                </LinearLayout>

                <!-- Price and Stock -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="GIÁ VÀ TỒN KHO"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/inputPrice"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Giá bán (VNĐ) *"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>

                    <EditText
                        android:id="@+id/inputCostPrice"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Giá vốn (VNĐ) - để tính lợi nhuận"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>

                    <EditText
                        android:id="@+id/inputStock"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Tồn kho hiện tại"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>

                    <EditText
                        android:id="@+id/inputMinStock"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Ngưỡng cảnh báo tồn kho"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"/>
                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="MÔ TẢ SẢN PHẨM"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <EditText
                        android:id="@+id/inputDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="96dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Mô tả, ghi chú về sản phẩm (tùy chọn)"
                        android:inputType="textMultiLine"
                        android:gravity="top|start"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:lines="4"
                        android:maxLines="8"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Save Button -->
        <LinearLayout
            android:id="@+id/btnSaveProduct"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_pos_cat_active"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Lưu sản phẩm" android:textColor="#FFFFFF"
                android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>

        <!-- Archive Button -->
        <TextView
            android:id="@+id/btnArchiveProduct"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="Ẩn sản phẩm"
            android:textColor="#EF4444"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

    </LinearLayout>
</FrameLayout>
