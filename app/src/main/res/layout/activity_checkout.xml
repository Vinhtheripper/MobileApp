<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ HEADER: AppBar + Amount ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2875FB"
            android:orientation="vertical"
            android:paddingTop="8dp"
            android:paddingBottom="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="16dp">
                <TextView
                    android:id="@+id/btnBack"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:text="←"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="Thanh toán"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CẦN THANH TOÁN"
                    android:textColor="#C8DDF8"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="6dp"/>
                <TextView
                    android:id="@+id/txtTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#FFFFFF"
                    android:textSize="36sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtSummaryItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#C8DDF8"
                    android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SCROLLABLE CONTENT ══ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Customer + Channel section -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="KHÁCH HÀNG (TÙY CHỌN)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <!-- Channel toggle -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/chipWalkIn"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="🏪  Tại quầy"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:background="@drawable/bg_chip_selected"
                        android:clickable="true"
                        android:focusable="true"/>

                    <TextView
                        android:id="@+id/chipSocial"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="📱  Đặt qua MXH"
                        android:textSize="13sp"
                        android:textColor="#64748B"
                        android:background="@android:color/transparent"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

                <EditText
                    android:id="@+id/inputCustomerPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:hint="Số điện thoại khách hàng"
                    android:inputType="phone"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"/>

                <EditText
                    android:id="@+id/inputCustomerName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:hint="Tên khách hàng"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"/>

                <EditText
                    android:id="@+id/inputCustomerAddress"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:hint="Địa chỉ giao hàng (nếu có)"
                    android:inputType="textPostalAddress"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"/>

                <!-- Loyalty section -->
                <LinearLayout
                    android:id="@+id/layoutLoyalty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:id="@+id/txtLoyaltyPoints"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Điểm tích lũy: 0 điểm"
                                android:textColor="#1C2333" android:textSize="13sp" android:textStyle="bold"/>
                            <TextView android:id="@+id/txtLoyaltyDiscount"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:text="Quy đổi tối đa: 0 ₫"
                                android:textColor="#64748B" android:textSize="12sp" android:layout_marginTop="2dp"/>
                        </LinearLayout>
                        <TextView android:id="@+id/btnToggleRedeem"
                            android:layout_width="wrap_content" android:layout_height="36dp"
                            android:text="Dùng điểm" android:textColor="#2875FB" android:textSize="13sp"
                            android:textStyle="bold" android:gravity="center"
                            android:paddingHorizontal="14dp" android:background="@drawable/bg_blue_summary"
                            android:clickable="true" android:focusable="true"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/layoutRedeemRow"
                        android:layout_width="match_parent" android:layout_height="36dp"
                        android:layout_marginTop="8dp" android:gravity="center_vertical"
                        android:orientation="horizontal" android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Giảm giá điểm thưởng"
                            android:textColor="#10B981" android:textSize="13sp"/>
                        <TextView android:id="@+id/txtRedeemAmount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="−0 ₫" android:textColor="#10B981"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Payment Methods Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="PHƯƠNG THỨC THANH TOÁN"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <!-- Row 1: Cash + VietQR -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/cardCash"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card_white_12"
                        android:elevation="1dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💵" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Tiền mặt" android:textColor="#1C2333" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/txtCashRadio"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_success_oval"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textSize="1sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardVietQR"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_12"
                        android:elevation="1dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="📱" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="QR VNPay" android:textColor="#1C2333" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/txtVietQRRadio"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_success_oval"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textSize="1sp"
                            android:visibility="invisible"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2: Wallet + Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:id="@+id/cardWallet"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_card_white_12"
                        android:elevation="1dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_momo"
                            android:scaleType="fitCenter"
                            android:contentDescription="MoMo"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="MoMo" android:textColor="#1C2333" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/txtWalletRadio"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_success_oval"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textSize="1sp"
                            android:visibility="invisible"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardBank"
                        android:layout_width="0dp"
                        android:layout_height="84dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_12"
                        android:elevation="1dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="💳" android:textSize="24sp"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Thẻ NFC" android:textColor="#1C2333" android:textSize="12sp" android:textStyle="bold"/>
                        <TextView
                            android:id="@+id/txtBankRadio"
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_success_oval"
                            android:layout_marginTop="4dp"
                            android:text=""
                            android:textSize="1sp"
                            android:visibility="invisible"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Cash input section -->
                <LinearLayout
                    android:id="@+id/layoutCashInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiền khách đưa"
                        android:textColor="#374151"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="10dp"/>

                    <EditText
                        android:id="@+id/inputReceived"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_pos_search"
                        android:hint="Nhập số tiền (VNĐ)"
                        android:inputType="number"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                    <!-- Preset chips -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/btnCashExact"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_pos_cat_active"
                            android:gravity="center"
                            android:text="Đủ tiền"
                            android:textColor="#FFFFFF"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btnCash100"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_card_white_12"
                            android:gravity="center"
                            android:text="100K"
                            android:textColor="#2875FB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btnCash200"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:background="@drawable/bg_card_white_12"
                            android:gravity="center"
                            android:text="200K"
                            android:textColor="#2875FB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btnCash500"
                            android:layout_width="0dp"
                            android:layout_height="36dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white_12"
                            android:gravity="center"
                            android:text="500K"
                            android:textColor="#2875FB"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- Change row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_blue_summary"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="12dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tiền thừa trả khách"
                            android:textColor="#1558B0"
                            android:textSize="13sp"/>
                        <TextView
                            android:id="@+id/txtChange"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 ₫"
                            android:textColor="#00885D"
                            android:textSize="16sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- QR display area (shown when VietQR selected) -->
                <LinearLayout
                    android:id="@+id/layoutQR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/imgVietQR"
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="@null"/>

                    <TextView
                        android:id="@+id/txtQRBankInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:text="Đang tải mã QR..."
                        android:textColor="#64748B"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txtQRAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#2875FB"
                        android:textSize="16sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- MoMo QR display area -->
                <LinearLayout
                    android:id="@+id/layoutMomoQR"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:visibility="gone">

                    <ImageView
                        android:id="@+id/imgMomoQR"
                        android:layout_width="220dp"
                        android:layout_height="220dp"
                        android:scaleType="fitCenter"
                        android:contentDescription="MoMo QR"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:text="Quét mã QR để thanh toán qua MoMo"
                        android:textColor="#64748B"
                        android:textSize="13sp"/>

                    <TextView
                        android:id="@+id/txtMomoQRAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="#AE2070"
                        android:textSize="16sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Wallet sub-options -->
                <LinearLayout
                    android:id="@+id/layoutWalletOptions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="12dp"
                    android:visibility="gone">

                    <LinearLayout android:id="@+id/btnWalletMomo"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:layout_marginEnd="6dp" android:gravity="center" android:orientation="horizontal"
                        android:background="@drawable/bg_pos_search"
                        android:clickable="true" android:focusable="true">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_momo"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="6dp"
                            android:contentDescription="@null"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="MoMo" android:textColor="#1C2333" android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnWalletZalo"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:layout_marginEnd="6dp" android:gravity="center" android:orientation="horizontal"
                        android:background="@drawable/bg_pos_search"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="ZaloPay" android:textColor="#1C2333" android:textSize="13sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/btnWalletViettel"
                        android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                        android:gravity="center" android:orientation="horizontal"
                        android:background="@drawable/bg_pos_search"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Viettel Pay" android:textColor="#1C2333" android:textSize="12sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- ══ CONFIRM BUTTON ══ -->
        <LinearLayout
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_btn_login_pill"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:orientation="horizontal">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xác nhận thanh toán"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</FrameLayout>
