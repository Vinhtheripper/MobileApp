<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/pos_background" android:fitsSystemWindows="true"><LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal"><Button android:id="@+id/btnBack" style="@style/Widget.Mpos.Button.Outline" android:layout_width="wrap_content" android:layout_height="44dp" android:minWidth="0dp" android:text="‹" android:textSize="28sp"/><TextView style="@style/TextAppearance.Mpos.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Xác nhận thanh toán"/></LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_orange_card" android:orientation="vertical" android:padding="20dp"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="TỔNG CẦN THANH TOÁN" android:textColor="#FFF3E0" android:textSize="12sp"/><TextView android:id="@+id/txtTotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:textColor="@color/pos_surface" android:textSize="34sp" android:textStyle="bold"/></LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Thông tin khách hàng" android:textColor="@color/pos_text" android:textStyle="bold"/>
    <EditText android:id="@+id/inputCustomerPhone" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:background="@drawable/bg_surface_card" android:hint="Số điện thoại khách (không bắt buộc)" android:inputType="phone" android:paddingHorizontal="14dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Phương thức thanh toán" android:textColor="@color/pos_text" android:textStyle="bold"/>
    <Spinner android:id="@+id/spinnerMethod" android:layout_width="match_parent" android:layout_height="52dp" android:background="@drawable/bg_surface_card"/>
    <EditText android:id="@+id/inputReceived" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="10dp" android:background="@drawable/bg_surface_card" android:hint="Tiền khách đưa (tiền mặt)" android:inputType="number" android:paddingHorizontal="14dp"/>
    <Button android:id="@+id/btnConfirmPayment" style="@style/Widget.Mpos.Button.Success" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="24dp" android:text="Xác nhận thanh toán"/>
</LinearLayout></ScrollView>
