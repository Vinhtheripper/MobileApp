<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- ── HEADER: shop logo + name + role ── -->
    <LinearLayout
        android:id="@+id/drawerHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_drawer_header"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="40dp"
        android:paddingBottom="24dp">

        <!-- Shop logo circle -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_white_alpha">

            <ImageView
                android:id="@+id/drawerShopLogo"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="Logo"/>

            <TextView
                android:id="@+id/drawerShopInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Q"
                android:textColor="#1565C0"
                android:textSize="26sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Shop name -->
        <TextView
            android:id="@+id/drawerShopName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Cửa hàng"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end"/>

        <!-- Role badge -->
        <TextView
            android:id="@+id/drawerRoleBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_drawer_role_chip"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:text="Chủ cửa hàng"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <!-- ── MENU ITEMS ── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- Cài đặt cửa hàng -->
            <LinearLayout
                android:id="@+id/drawerItemShopSettings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_settings"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Cài đặt cửa hàng"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Quản lý nhân viên -->
            <LinearLayout
                android:id="@+id/drawerItemStaff"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_people"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Quản lý nhân viên"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Báo cáo -->
            <LinearLayout
                android:id="@+id/drawerItemReports"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chart"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Báo cáo doanh thu"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Hỗ trợ -->
            <LinearLayout
                android:id="@+id/drawerItemSupport"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_help"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Hỗ trợ"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Giới thiệu & Nhận thưởng -->
            <LinearLayout
                android:id="@+id/drawerItemReferral"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_share"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Giới thiệu &amp; Nhận thưởng"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Đánh giá ứng dụng -->
            <LinearLayout
                android:id="@+id/drawerItemRate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_star_outline"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Đánh giá ứng dụng"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Cài đặt cá nhân -->
            <LinearLayout
                android:id="@+id/drawerItemProfile"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_person"
                    android:tint="#1565C0"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Cài đặt cá nhân"
                    android:textColor="#1C2333"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="#E2E8F0"/>

            <!-- Đổi cửa hàng -->
            <LinearLayout
                android:id="@+id/drawerItemSwitchShop"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_switch_shop"
                    android:tint="#64748B"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Đổi cửa hàng"
                    android:textColor="#64748B"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Đăng xuất -->
            <LinearLayout
                android:id="@+id/drawerItemLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_drawer_item_ripple">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_logout"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="Đăng xuất"
                    android:textColor="#EF4444"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ── VERSION TEXT ── -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:paddingTop="12dp"
        android:paddingBottom="20dp"
        android:text="Quầy mPOS Pro · Phiên bản 1.0.0"
        android:textColor="#94A3B8"
        android:textSize="11sp"/>

</LinearLayout>
