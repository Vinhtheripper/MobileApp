<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E3472"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- TOP: Blue section with mascot -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.38"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="48dp"
            android:paddingBottom="12dp">

            <ImageView
                android:id="@+id/imgMascot"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:src="@drawable/ic_logo_bg"
                android:scaleType="fitCenter"
                android:contentDescription="Quầy"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="Chào mừng trở lại"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="Đăng nhập để bắt đầu ca bán hàng"
                android:textColor="#93B4EF"
                android:textSize="13sp"/>
        </LinearLayout>

        <!-- BOTTOM: White card with form -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.62"
            android:background="@drawable/bg_login_wave_panel_glass"
            android:fillViewport="true"
            android:overScrollMode="never"
            android:elevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="30dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng nhập"
                    android:textColor="#1C2333"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập thông tin tài khoản của bạn"
                    android:textColor="#64748B"
                    android:textSize="13sp"
                    android:layout_marginBottom="22dp"/>

                <!-- Email label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp">
                    <EditText
                        android:id="@+id/inputEmail"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_login_pill"
                        android:hint="email@cuahang.com"
                        android:inputType="textEmailAddress"
                        android:paddingStart="48dp"
                        android:paddingEnd="16dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:imeOptions="actionNext"
                        android:singleLine="true"/>
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="52dp"
                        android:layout_gravity="start|center_vertical"
                        android:src="@drawable/ic_person_input"
                        android:scaleType="center"
                        android:padding="14dp"
                        android:contentDescription="@null"/>
                </FrameLayout>

                <!-- Password label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mật khẩu"
                    android:textColor="#374151"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="52dp">
                    <EditText
                        android:id="@+id/inputPassword"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_login_pill"
                        android:hint="Mật khẩu"
                        android:inputType="textPassword"
                        android:paddingStart="48dp"
                        android:paddingEnd="52dp"
                        android:textColor="#1C2333"
                        android:textColorHint="#9CA3AF"
                        android:textSize="14sp"
                        android:imeOptions="actionDone"
                        android:singleLine="true"/>
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="52dp"
                        android:layout_gravity="start|center_vertical"
                        android:src="@drawable/ic_lock_input"
                        android:scaleType="center"
                        android:padding="14dp"
                        android:contentDescription="@null"/>
                    <ImageView
                        android:id="@+id/btnTogglePassword"
                        android:layout_width="48dp"
                        android:layout_height="52dp"
                        android:layout_gravity="end|center_vertical"
                        android:src="@drawable/ic_eye_off"
                        android:scaleType="center"
                        android:padding="14dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Hiện/ẩn mật khẩu"/>
                </FrameLayout>

                <!-- Forgot password -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="4dp">
                    <TextView
                        android:id="@+id/btnForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:gravity="center_vertical"
                        android:text="Quên mật khẩu?"
                        android:textColor="#2875FB"
                        android:textSize="12sp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackgroundBorderless"/>
                </LinearLayout>

                <!-- Error message -->
                <TextView
                    android:id="@+id/txtLoginError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/badge_error"
                    android:padding="10dp"
                    android:textColor="@color/status_error"
                    android:textSize="13sp"
                    android:visibility="gone"/>

                <!-- Login button -->
                <TextView
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_btn_login_pill"
                    android:gravity="center"
                    android:text="Đăng nhập"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="2dp"/>

                <!-- Divider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#DDE3EE"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_marginEnd="12dp"
                        android:text="hoặc đăng nhập với"
                        android:textColor="#94A3B8"
                        android:textSize="12sp"/>
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#DDE3EE"/>
                </LinearLayout>

                <!-- Google button -->
                <LinearLayout
                    android:id="@+id/btnGoogleSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_btn_google"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:elevation="1dp">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginEnd="10dp"
                        android:src="@drawable/ic_google"
                        android:scaleType="fitCenter"
                        android:contentDescription="Google"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng nhập với Google"
                        android:textColor="#3C4043"
                        android:textSize="14sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Hidden Facebook button — keep ID for Java -->
                <LinearLayout
                    android:id="@+id/btnFacebookSignIn"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:visibility="gone"/>

                <!-- Register link -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa có cửa hàng? "
                        android:textColor="#64748B"
                        android:textSize="13sp"/>
                    <TextView
                        android:id="@+id/btnRegister"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Đăng ký ngay"
                        android:textColor="#2875FB"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>

</FrameLayout>
