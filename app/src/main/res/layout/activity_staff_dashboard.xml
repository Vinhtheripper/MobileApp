<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fitsSystemWindows="true">

    <!-- ===== SCROLLABLE CONTENT ===== -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="80dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="80dp">

            <!-- ===== 1. Alert Banner — low stock warning ===== -->
            <LinearLayout android:id="@+id/layoutAlertBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_alert_banner_warning"
                android:clickable="true"
                android:elevation="1dp"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Icon + message -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_inventory"
                        android:tint="#F57C00"/>
                    <TextView android:id="@+id/txtAlertMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="3 sản phẩm sắp hết hàng"
                        android:textColor="#F57C00"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- "Xem ngay →" link -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Xem ngay →"
                    android:textColor="#F57C00"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- ===== 2. Today Summary Card ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card_white_16"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Label: CA HÔM NAY -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="CA HÔM NAY"
                    android:textAllCaps="true"
                    android:textColor="#6B7280"
                    android:textSize="16sp"/>

                <!-- Order count | Revenue -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/txtShiftOrderCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="#1C2333"
                        android:textSize="28sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:text="|"
                        android:textColor="#D1D5DB"
                        android:textSize="16sp"/>
                    <TextView android:id="@+id/txtShiftRevenue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 ₫"
                        android:textColor="#1C2333"
                        android:textSize="24sp"
                        android:textStyle="bold"/>
                </LinearLayout>

                <!-- Shift info row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/txtShiftInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🕐 Chưa mở ca làm việc"
                        android:textColor="#5F6368"
                        android:textSize="14sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== 3. Quick Actions 2×2 Grid ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal">

                    <!-- Tạo đơn mới -->
                    <LinearLayout android:id="@+id/btnNewSale"
                        android:layout_width="0dp"
                        android:layout_height="114dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_16"
                        android:clickable="true"
                        android:elevation="2dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle_blue">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="🛒"
                                android:textSize="20sp"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="Tạo đơn mới"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Quét barcode -->
                    <LinearLayout android:id="@+id/btnScanBarcode"
                        android:layout_width="0dp"
                        android:layout_height="114dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_16"
                        android:clickable="true"
                        android:elevation="2dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle_green">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📷"
                                android:textSize="20sp"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="Quét barcode"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Xem đơn hàng -->
                    <LinearLayout android:id="@+id/btnViewOrders"
                        android:layout_width="0dp"
                        android:layout_height="114dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_16"
                        android:clickable="true"
                        android:elevation="2dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle_orange">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="📋"
                                android:textSize="20sp"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="Xem đơn hàng"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Khách hàng -->
                    <LinearLayout android:id="@+id/btnCustomers"
                        android:layout_width="0dp"
                        android:layout_height="114dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_card_white_16"
                        android:clickable="true"
                        android:elevation="2dp"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="16dp">
                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_circle_purple">
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:gravity="center"
                                android:text="👤"
                                android:textSize="20sp"/>
                        </FrameLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:gravity="center"
                            android:text="Khách hàng"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== 4. Recent Orders Section ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical">

                <!-- Header: "Đơn gần đây" + "Xem tất" -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="4dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đơn gần đây"
                        android:textColor="#1C2333"
                        android:textSize="20sp"/>
                    <TextView android:id="@+id/btnViewAllOrders"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="Xem tất"
                        android:textColor="#1A73E8"
                        android:textSize="16sp"/>
                </LinearLayout>

                <!-- Order Row 1 -->
                <LinearLayout android:id="@+id/layoutOrder1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_card_white_12"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone">

                    <!-- Icon box -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_order_icon_box">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="🧾"
                            android:textSize="16sp"/>
                    </FrameLayout>

                    <!-- Order info -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView android:id="@+id/txtOrder1Code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.01"
                                android:textColor="#1C2333"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView android:id="@+id/txtOrder1Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:id="@+id/txtOrder1Customer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#6B7280"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Amount + pay status -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtOrder1Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="#1C2333"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView android:id="@+id/txtOrder1Pay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Order Row 2 -->
                <LinearLayout android:id="@+id/layoutOrder2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_white_12"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_order_icon_box">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="🧾"
                            android:textSize="16sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView android:id="@+id/txtOrder2Code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.01"
                                android:textColor="#1C2333"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView android:id="@+id/txtOrder2Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:id="@+id/txtOrder2Customer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#6B7280"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtOrder2Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="#1C2333"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView android:id="@+id/txtOrder2Pay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Order Row 3 -->
                <LinearLayout android:id="@+id/layoutOrder3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_card_white_12"
                    android:clickable="true"
                    android:elevation="2dp"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:visibility="gone">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_order_icon_box">
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="🧾"
                            android:textSize="16sp"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <TextView android:id="@+id/txtOrder3Code"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:letterSpacing="0.01"
                                android:textColor="#1C2333"
                                android:textSize="14sp"
                                android:textStyle="bold"/>
                            <TextView android:id="@+id/txtOrder3Status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:paddingTop="2dp"
                                android:paddingBottom="2dp"
                                android:textColor="#FFFFFF"
                                android:textSize="10sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                        <TextView android:id="@+id/txtOrder3Customer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="#6B7280"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:orientation="vertical">
                        <TextView android:id="@+id/txtOrder3Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:textColor="#1C2333"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                        <TextView android:id="@+id/txtOrder3Pay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Empty state (shown when no orders) -->
                <TextView android:id="@+id/txtNoOrders"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:padding="24dp"
                    android:text="Chưa có đơn hàng nào hôm nay"
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:visibility="gone"/>
            </LinearLayout>

            <!-- ===== 5. Inventory Info Banner ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_inventory_info"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Quản lý kho thông minh"
                    android:textColor="#1C2333"
                    android:textSize="18sp"/>
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:maxWidth="240dp"
                    android:text="Tự động cập nhật tồn kho khi phát sinh đơn hàng tại quầy."
                    android:textColor="#6B7280"
                    android:textSize="14sp"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- ===== TOP APP BAR (#1C2333, absolute top) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="top"
        android:background="#1C2333"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- Avatar circle (#1A73E8) + Name + Role -->
        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_circle_blue">
            <TextView android:id="@+id/txtStaffInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="A"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- Name + Role text block -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">
            <TextView android:id="@+id/txtStaffName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xin chào, Nhân viên"
                android:textColor="#FFFFFF"
                android:textSize="16sp"/>
            <TextView android:id="@+id/txtStaffRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nhân viên"
                android:textColor="#9CA3AF"
                android:textSize="11sp"/>
        </LinearLayout>

        <!-- Notification bell with badge -->
        <FrameLayout
            android:id="@+id/btnNotification"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                android:tint="#FFFFFF"/>
            <TextView android:id="@+id/txtNotificationBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_badge_pill_red"
                android:gravity="center"
                android:text="!"
                android:textColor="#FFFFFF"
                android:textSize="8sp"
                android:textStyle="bold"
                android:visibility="gone"/>
        </FrameLayout>
    </LinearLayout>

    <!-- ===== BOTTOM NAVIGATION ===== -->
    <include
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav_staff"/>

</FrameLayout>