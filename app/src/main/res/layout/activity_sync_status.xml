<?xml version="1.0" encoding="utf-8"?>
<!--
    SYNC STATUS — Quầy mPOS Pro
    Shows Firebase sync health, last sync time, channel statuses.
    Mascot "offline" state when disconnected.
    Built from 7-line stub.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ WHITE APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Trạng thái đồng bộ"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_gutter"
                android:paddingEnd="@dimen/screen_gutter"
                android:paddingTop="16dp"
                android:paddingBottom="32dp">

                <!-- ── HERO STATUS CARD ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="28dp">

                    <!-- Mascot / Status icon -->
                    <ImageView
                        android:id="@+id/imgSyncIcon"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_mascot"
                        android:scaleType="fitCenter"
                        android:contentDescription="Trạng thái kết nối"/>

                    <!-- Status label -->
                    <TextView
                        android:id="@+id/txtSyncStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="Đang kiểm tra..."
                        android:textColor="@color/text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- Last sync time -->
                    <TextView
                        android:id="@+id/txtLastSync"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Chưa đồng bộ"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"/>

                    <!-- Status chip -->
                    <TextView
                        android:id="@+id/txtSyncStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:background="@drawable/badge_info"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:text="Đang kết nối"
                        android:textColor="@color/blue_primary"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                    <!-- Sync now button -->
                    <Button
                        android:id="@+id/btnSyncNow"
                        style="@style/Widget.Mpos.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:text="Đồng bộ ngay"/>
                </LinearLayout>

                <!-- ── CHANNEL SYNC STATUS ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Trạng thái kênh"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <!-- Firebase -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_orange_light"
                        android:gravity="center">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_upload" android:tint="#F97316"/>
                    </LinearLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Firebase Firestore"
                        android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/txtFirebaseStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/badge_success"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:text="Đã kết nối"
                        android:textColor="@color/status_success" android:textSize="11sp"/>
                </LinearLayout>

                <!-- Spacer -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border"/>

                <!-- Local DB -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">
                    <LinearLayout
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_icon_blue_light"
                        android:gravity="center">
                        <ImageView android:layout_width="16dp" android:layout_height="16dp"
                            android:src="@drawable/ic_inventory" android:tint="@color/blue_primary"/>
                    </LinearLayout>
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:layout_marginStart="12dp"
                        android:text="Cơ sở dữ liệu cục bộ"
                        android:textColor="@color/text_primary" android:textSize="14sp"/>
                    <TextView android:id="@+id/txtLocalDbStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:background="@drawable/badge_success"
                        android:paddingStart="10dp" android:paddingEnd="10dp"
                        android:paddingTop="4dp" android:paddingBottom="4dp"
                        android:text="Bình thường"
                        android:textColor="@color/status_success" android:textSize="11sp"/>
                </LinearLayout>

                <!-- ── PENDING ITEMS ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Hàng đợi đồng bộ"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Đơn hàng chờ đồng bộ"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtPendingOrders"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Sản phẩm chờ đồng bộ"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtPendingProducts"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
