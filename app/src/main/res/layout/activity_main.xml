<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/pos_background" android:fillViewport="true" android:fitsSystemWindows="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="@dimen/space_md">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical"><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="mPOS Pro" android:textColor="@color/pos_orange_dark" android:textStyle="bold"/><TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="Tổng quan vận hành cửa hàng" android:textColor="@color/pos_text_secondary" /></LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:background="@drawable/bg_chip_success" android:paddingHorizontal="12dp" android:paddingVertical="8dp" android:text="● Offline ready" android:textColor="@color/pos_success" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_md" android:background="@drawable/bg_orange_card" android:orientation="vertical" android:padding="20dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DOANH THU HÔM NAY" android:textColor="#FFF3E0" android:textSize="12sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="0 ₫" android:textColor="@color/pos_surface" android:textSize="34sp" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:text="Ca hiện tại: chưa mở" android:textColor="#FFF3E0"/>
        </LinearLayout>
        <Button android:id="@+id/btnNewSale" style="@style/Widget.Mpos.Button.Primary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_md" android:text="Bắt đầu bán hàng" />
        <TextView style="@style/TextAppearance.Mpos.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_lg" android:text="Thao tác nhanh" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_sm" android:orientation="horizontal">
            <Button android:id="@+id/btnShift" style="@style/Widget.Mpos.Button.Outline" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:layout_weight="1" android:text="Ca làm việc" />
            <Button android:id="@+id/btnInbox" style="@style/Widget.Mpos.Button.Outline" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="4dp" android:layout_weight="1" android:text="Đơn đa kênh" />
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_sm" android:orientation="horizontal">
            <include layout="@layout/view_dashboard_stat"/><include layout="@layout/view_dashboard_stat"/>
        </LinearLayout>
        <Button android:id="@+id/btnSync" style="@style/Widget.Mpos.Button.Outline" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_md" android:text="Trạng thái đồng bộ" />
        <Button android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="@dimen/space_sm" android:text="Đăng xuất" android:textColor="@color/pos_error" />
    </LinearLayout>
</ScrollView>
