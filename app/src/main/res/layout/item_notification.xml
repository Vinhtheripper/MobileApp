<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#FFFFFF"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="16dp"
    android:layout_marginBottom="1dp">

    <!-- Icon circle -->
    <LinearLayout
        android:id="@+id/layoutNotifIcon"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_blue_summary"
        android:gravity="center"
        android:orientation="vertical">
        <ImageView
            android:id="@+id/imgNotifIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_notification"
            android:tint="#1A73E8"/>
    </LinearLayout>

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:orientation="vertical">
        <TextView
            android:id="@+id/txtNotifTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1C2333"
            android:textSize="13sp"
            android:textStyle="bold"/>
        <TextView
            android:id="@+id/txtNotifBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textColor="#64748B"
            android:textSize="12sp"/>
        <TextView
            android:id="@+id/txtNotifTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#94A3B8"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Unread dot -->
    <View
        android:id="@+id/viewUnread"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_success_oval"
        android:visibility="visible"/>
</LinearLayout>
