<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="64dp">

        <!-- AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1C2333"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Kho hàng"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/btnStockAdjust"
                android:layout_width="wrap_content"
                android:layout_height="34dp"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_circle_blue"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nhập kho" android:textColor="#FFFFFF" android:textSize="13sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Stats Bento Grid (4 tiles) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_stat_tile"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtStatTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#1C2333"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tổng SP" android:textColor="#64748B" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_stat_tile"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtStatLow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#EAB308"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tồn thấp" android:textColor="#64748B" android:textSize="10sp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_tile"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtStatOut"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#EF4444"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Hết hàng" android:textColor="#64748B" android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Action row: Lịch sử -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/btnInventoryHistory"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="📋  Lịch sử biến động"
                android:textColor="#1A73E8"
                android:textSize="13sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#E2E8F0"/>

        <!-- Inventory List -->
        <ListView
            android:id="@+id/listInventory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"/>
    </LinearLayout>

    <!-- Staff Bottom Nav (Kho active) -->
    <include
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav_inventory"/>

</FrameLayout>
