<?xml version="1.0" encoding="utf-8"?>
<!--
    AI CHAT SCREEN — Quầy mPOS Pro
    Mascot avatar in header bar
    Bot messages include small mascot avatar
    Montserrat font for header title
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#EEF2FF"
    android:fitsSystemWindows="true">

    <!-- ── AppBar with mascot ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/blue_navy"
        android:elevation="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="4dp"
        android:paddingEnd="8dp">

        <!-- Back button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="←"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>

        <!-- Mascot avatar + title group -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Mascot avatar circle -->
            <FrameLayout
                android:layout_width="46dp"
                android:layout_height="46dp">

                <ImageView
                    android:id="@+id/imgChatMascot"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_mascot_png"
                    android:scaleType="centerCrop"
                    android:background="@drawable/bg_chat_mascot_avatar"
                    android:clipToOutline="true"
                    android:contentDescription="AI Mascot"/>

                <!-- Online dot indicator -->
                <View
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="bottom|end"
                    android:background="@drawable/bg_online_dot"
                    android:layout_marginBottom="1dp"
                    android:layout_marginEnd="1dp"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Trợ lý kinh doanh"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● Trực tuyến · Claude AI"
                    android:textColor="#90C8FF"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- API key button -->
        <TextView
            android:id="@+id/btnApiKey"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="🔑"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"/>
    </LinearLayout>

    <!-- Loading bar -->
    <ProgressBar
        android:id="@+id/progressChat"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:visibility="gone"
        android:indeterminate="true"
        android:progressTint="@color/blue_primary"
        android:indeterminateTint="@color/blue_primary"/>

    <!-- Chat messages scroll -->
    <ScrollView
        android:id="@+id/scrollMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <LinearLayout
            android:id="@+id/layoutMessages"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="8dp"/>
    </ScrollView>

    <!-- Quick question chips -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="#FFFFFF"
        android:paddingTop="8dp"
        android:paddingBottom="6dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/layoutChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"/>
    </HorizontalScrollView>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:elevation="4dp">

        <EditText
            android:id="@+id/etChatInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_input_field"
            android:hint="Hỏi về doanh thu, tồn kho..."
            android:maxLines="4"
            android:minLines="1"
            android:paddingHorizontal="14dp"
            android:paddingVertical="10dp"
            android:textSize="14sp"
            android:fontFamily="sans-serif"/>

        <TextView
            android:id="@+id/btnChatSend"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_primary_circle"
            android:gravity="center"
            android:text="➤"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

</LinearLayout>
