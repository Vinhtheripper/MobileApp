<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/app_background" android:fitsSystemWindows="true" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_top_bar" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:clickable="true" android:focusable="true" android:gravity="center" android:text="←" android:textColor="@color/surface" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="Hồ sơ" android:textColor="@color/surface" android:textSize="15sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_surface_card" android:gravity="center_horizontal" android:orientation="vertical" android:padding="18dp">
            <TextView android:layout_width="72dp" android:layout_height="72dp" android:background="@drawable/bg_logo_tile" android:gravity="center" android:text="A" android:textColor="@color/surface" android:textSize="28sp" android:textStyle="bold" />
            <TextView android:id="@+id/txtProfileInfo" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:gravity="center" android:textColor="@color/deep_navy_text" android:textSize="17sp" android:textStyle="bold" />
        </LinearLayout>
        <Button android:id="@+id/btnSettings" style="@style/Widget.Mpos.Button.Outline" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="14dp" android:text="Cấu hình cửa hàng" />
        <Button android:id="@+id/btnProfileLogout" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:text="Đăng xuất" android:textColor="@color/status_error" />
    </LinearLayout>
</LinearLayout>
