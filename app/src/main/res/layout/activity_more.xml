<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/app_background" android:fitsSystemWindows="true">
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:clipToPadding="false" android:paddingBottom="96dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_top_bar" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="16dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tiện ích" android:textColor="@color/surface" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Quản lý cửa hàng và thiết lập hệ thống" android:textColor="@color/text_secondary" android:textSize="12sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Vận hành" android:textColor="@color/deep_navy_text" android:textSize="17sp" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_surface_card" android:orientation="vertical" android:padding="8dp">
                    <Button android:id="@+id/itemShift" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Ca làm việc" />
                    <Button android:id="@+id/itemSync" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Đồng bộ dữ liệu" />
                    <Button android:id="@+id/itemInbox" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Unified Inbox" />
                    <Button android:id="@+id/itemFulfillment" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Fulfillment &amp; giao hàng" />
                </LinearLayout>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Quản lý" android:textColor="@color/deep_navy_text" android:textSize="17sp" android:textStyle="bold" />
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_surface_card" android:orientation="vertical" android:padding="8dp">
                    <Button android:id="@+id/itemProducts" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Sản phẩm" />
                    <Button android:id="@+id/itemCustomers" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Khách hàng" />
                    <Button android:id="@+id/itemProfile" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Hồ sơ &amp; Cài đặt" />
                </LinearLayout>
                <TextView android:id="@+id/labelAdmin" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:text="Admin" android:textColor="@color/deep_navy_text" android:textSize="17sp" android:textStyle="bold" />
                <LinearLayout android:id="@+id/groupAdmin" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/bg_surface_card" android:orientation="vertical" android:padding="8dp">
                    <Button android:id="@+id/itemUsers" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Tài khoản nhân viên" />
                    <Button android:id="@+id/itemSettings" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Cấu hình cửa hàng" />
                    <Button android:id="@+id/itemAudit" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="54dp" android:gravity="start|center_vertical" android:text="Nhật ký hoạt động" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <include layout="@layout/include_bottom_nav" android:layout_width="match_parent" android:layout_height="76dp" android:layout_gravity="bottom" />
</FrameLayout>
