<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="96dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tiện ích"
                android:textColor="#1C2333"
                android:textSize="22sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Quản lý cửa hàng và thiết lập hệ thống"
                android:textColor="#64748B"
                android:textSize="13sp"/>

            <!-- Section: Kết nối kênh -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:text="KẾT NỐI KÊNH"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white_12"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Sàn TMĐT -->
                <LinearLayout
                    android:id="@+id/itemOmnichannel"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_orange_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_orders"
                            android:tint="#EE4D2D"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Sàn TMĐT (Shopee · TikTok · Lazada)"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription="@null"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Vận chuyển -->
                <LinearLayout
                    android:id="@+id/itemShipping"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_green_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_inventory"
                            android:tint="#10B981"
                            android:contentDescription="@null"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Vận chuyển (GHN · GHTK · VTP)"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription="@null"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Section: Vận hành -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="VẬN HÀNH"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white_12"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Ca làm việc -->
                <LinearLayout
                    android:id="@+id/itemShift"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_purple_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_settings"
                            android:tint="#8B5CF6"
                            android:contentDescription="Ca"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Ca làm việc"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Đồng bộ -->
                <LinearLayout
                    android:id="@+id/itemSync"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_blue_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_upload"
                            android:tint="@color/blue_primary"
                            android:contentDescription="Sync"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Đồng bộ dữ liệu"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Unified Inbox -->
                <LinearLayout
                    android:id="@+id/itemInbox"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_orange_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_notification"
                            android:tint="#F97316"
                            android:contentDescription="Inbox"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Hộp thư hợp nhất"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>
            </LinearLayout>

            <!-- Section: Quản lý -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="QUẢN LÝ"
                android:textColor="#64748B"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card_white_12"
                android:elevation="1dp"
                android:orientation="vertical"
                android:padding="4dp">

                <!-- Sản phẩm -->
                <LinearLayout
                    android:id="@+id/itemProducts"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_orange_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_products"
                            android:tint="#F97316"
                            android:contentDescription="Sản phẩm"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Sản phẩm"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Khách hàng -->
                <LinearLayout
                    android:id="@+id/itemCustomers"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_green_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_customers"
                            android:tint="#10B981"
                            android:contentDescription="Khách"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Khách hàng"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Nhân viên -->
                <LinearLayout
                    android:id="@+id/itemEmployees"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_blue_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_person"
                            android:tint="@color/blue_primary"
                            android:contentDescription="Nhân viên"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Nhân viên"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#F1F5F9" android:layout_marginStart="60dp"/>

                <!-- Hồ sơ & Cài đặt -->
                <LinearLayout
                    android:id="@+id/itemProfile"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp">
                    <LinearLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_icon_gray_light"
                        android:gravity="center">
                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:src="@drawable/ic_settings"
                            android:tint="#64748B"
                            android:contentDescription="Cài đặt"/>
                    </LinearLayout>
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Hồ sơ &amp; Cài đặt"
                        android:textColor="#1C2333"
                        android:textSize="14sp"/>
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_more_vert"
                        android:tint="#CBD5E1"
                        android:contentDescription=""/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav"/>
</FrameLayout>