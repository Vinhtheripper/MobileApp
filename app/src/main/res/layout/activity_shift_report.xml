<?xml version="1.0" encoding="utf-8"?>
<!--
    SHIFT REPORT SCREEN — Quầy mPOS Pro
    Built out from 1KB stub. Shows full shift summary:
    opening cash, orders, revenue, closing cash, difference.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Báo cáo ca"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <!-- Share / print -->
            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_share"
                android:tint="@color/text_secondary"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Chia sẻ báo cáo"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:clipToPadding="false"
            android:paddingBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/screen_gutter"
                android:paddingEnd="@dimen/screen_gutter"
                android:paddingTop="16dp">

                <!-- ── HERO: Shift code + date ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_hero_flat_blue"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CA LÀM VIỆC"
                        android:textColor="#C3D7FC"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08"/>

                    <TextView
                        android:id="@+id/txtShiftCode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="—"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mở ca"
                                android:textColor="#C3D7FC"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/txtOpenTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Đóng ca"
                                android:textColor="#C3D7FC"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/txtCloseTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="end"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nhân viên"
                                android:textColor="#C3D7FC"
                                android:textSize="11sp"/>
                            <TextView
                                android:id="@+id/txtCashier"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── REVENUE SUMMARY ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Doanh thu"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Total revenue row -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Tổng doanh thu"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtTotalRevenue"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 ₫" android:textColor="@color/blue_primary"
                            android:textSize="16sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="10dp"/>

                    <!-- Orders count -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Số đơn hàng"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtOrderCount"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0" android:textColor="@color/text_primary"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="10dp"/>

                    <!-- Avg order value -->
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Trung bình / đơn"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtAvgOrder"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 ₫" android:textColor="@color/text_primary"
                            android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── CASH SUMMARY ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Tiền mặt"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Tiền đầu ca"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtOpeningCash"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 ₫" android:textColor="@color/text_primary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Tiền thực tế"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtActualCash"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 ₫" android:textColor="@color/text_primary"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/border" android:layout_marginVertical="10dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Chênh lệch"
                            android:textColor="@color/text_secondary" android:textSize="14sp"/>
                        <TextView android:id="@+id/txtDifference"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0 ₫" android:textColor="@color/status_success"
                            android:textSize="14sp" android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- ── HANDOVER NOTE ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="10dp"
                    android:text="Ghi chú bàn giao"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_surface"
                    android:elevation="@dimen/card_elevation"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/txtHandoverNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Không có ghi chú"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:lineSpacingMultiplier="1.4"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
