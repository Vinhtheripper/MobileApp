<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F9"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="76dp">

        <!-- AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/blue_navy"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="‹"
                android:textColor="#FFFFFF"
                android:textSize="24sp"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Báo cáo"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Period Filter Tabs -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:elevation="2dp">

            <TextView
                android:id="@+id/tab7days"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:background="@drawable/bg_tab_selected"
                android:gravity="center"
                android:text="7 ngày"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tab30days"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_tab_unselected"
                android:gravity="center"
                android:text="30 ngày"
                android:textColor="#64748B"
                android:textSize="13sp"/>

            <TextView
                android:id="@+id/tabThisMonth"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:background="@drawable/bg_tab_unselected"
                android:gravity="center"
                android:text="Tháng này"
                android:textColor="#64748B"
                android:textSize="13sp"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Summary KPI Grid (2×2) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Row 1: Revenue + Orders -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal">

                        <!-- Revenue card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_card_white_12"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_blue"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="₫" android:textColor="#2875FB" android:textSize="17sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Doanh thu" android:textColor="#94A3B8" android:textSize="11sp"/>
                                <TextView
                                    android:id="@+id/txtSummaryRevenue"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="0 ₫" android:textColor="#2875FB"
                                    android:textSize="14sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Orders card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white_12"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_green"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="#" android:textColor="#10B981" android:textSize="18sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Số đơn" android:textColor="#94A3B8" android:textSize="11sp"/>
                                <TextView
                                    android:id="@+id/txtSummaryOrders"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="0" android:textColor="#10B981"
                                    android:textSize="14sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Row 2: Avg + VAT -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Avg order card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="6dp"
                            android:background="@drawable/bg_card_white_12"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_orange"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="≈" android:textColor="#F59E0B" android:textSize="20sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="TB / đơn" android:textColor="#94A3B8" android:textSize="11sp"/>
                                <TextView
                                    android:id="@+id/txtSummaryAvg"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="0 ₫" android:textColor="#F59E0B"
                                    android:textSize="14sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>

                        <!-- VAT card -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/bg_card_white_12"
                            android:orientation="horizontal"
                            android:padding="14dp"
                            android:gravity="center_vertical">
                            <LinearLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/bg_icon_circle_purple"
                                android:gravity="center"
                                android:layout_marginEnd="10dp">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="%" android:textColor="#8B5CF6" android:textSize="17sp" android:textStyle="bold"/>
                            </LinearLayout>
                            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:orientation="vertical">
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:text="Thuế VAT" android:textColor="#94A3B8" android:textSize="11sp"/>
                                <TextView
                                    android:id="@+id/txtSummaryVat"
                                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                                    android:layout_marginTop="3dp"
                                    android:text="0 ₫" android:textColor="#8B5CF6"
                                    android:textSize="14sp" android:textStyle="bold"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Revenue Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doanh thu theo ngày"
                        android:textColor="#1C2333"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <com.example.mpos.report.LineChartView
                        android:id="@+id/revenueChart"
                        android:layout_width="match_parent"
                        android:layout_height="200dp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <!-- Top Products Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sản phẩm bán chạy"
                        android:textColor="#1C2333"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <LinearLayout
                        android:id="@+id/layoutTopProducts"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"/>
                </LinearLayout>

                <!-- Recent Orders Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Đơn hàng gần đây"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/txtOrderCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#94A3B8"
                            android:textSize="12sp"/>
                    </LinearLayout>

                    <!-- Table header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="32dp"
                        android:background="#F8FAFC"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Mã đơn"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:text="Thời gian"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:gravity="end"
                            android:text="Tổng tiền"
                            android:textColor="#94A3B8"
                            android:textSize="11sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutRecentOrders"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <!-- Low Stock Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/bg_card_white_12"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="14dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cảnh báo tồn kho"
                            android:textColor="#1C2333"
                            android:textSize="14sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/txtLowStockBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_badge_red"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="2dp"
                            android:textColor="#FFFFFF"
                            android:textSize="11sp"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutLowStock"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingBottom="4dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <include
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav"/>
</FrameLayout>
