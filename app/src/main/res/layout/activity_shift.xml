<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_top_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="←"
            android:textColor="@color/surface"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:text="Quản lý ca"
            android:textColor="@color/surface"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:id="@+id/txtShiftStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/badge_blue"
            android:padding="14dp"
            android:textColor="@color/blue_primary_dark"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputShiftCash"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_field_soft"
            android:hint="Tiền đầu/cuối ca"
            android:inputType="number"
            android:paddingHorizontal="14dp"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/inputHandoverNote"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_field_soft"
            android:hint="Ghi chú bàn giao"
            android:inputType="text"
            android:paddingHorizontal="14dp"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnOpenShift"
            style="@style/Widget.Mpos.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="Mở ca" />

        <Button
            android:id="@+id/btnCloseShift"
            style="@style/Widget.Mpos.Button.Outline"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="Đóng ca" />

        <Button
            android:id="@+id/btnShiftReport"
            style="@style/Widget.Mpos.Button.Ghost"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Xem báo cáo ca" />
    </LinearLayout>
</LinearLayout>
