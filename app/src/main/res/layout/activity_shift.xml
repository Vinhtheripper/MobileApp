<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/pos_background" android:fitsSystemWindows="true" android:orientation="vertical" android:padding="20dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal"><Button android:id="@+id/btnBack" style="@style/Widget.Mpos.Button.Outline" android:layout_width="wrap_content" android:layout_height="44dp" android:minWidth="0dp" android:text="‹" android:textSize="28sp"/><TextView style="@style/TextAppearance.Mpos.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Quản lý ca" /></LinearLayout>
    <TextView android:id="@+id/txtShiftStatus" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:textSize="18sp" />
    <EditText android:id="@+id/inputShiftCash" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Tiền đầu/cuối ca" android:inputType="number" />
    <EditText android:id="@+id/inputHandoverNote" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Ghi chú bàn giao" />
    <Button android:id="@+id/btnOpenShift" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Mở ca" />
    <Button android:id="@+id/btnCloseShift" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Đóng ca" />
</LinearLayout>
