<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/app_background" android:fitsSystemWindows="true" android:orientation="vertical" android:padding="20dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal"><Button android:id="@+id/btnBack" style="@style/Widget.Mpos.Button.Outline" android:layout_width="wrap_content" android:layout_height="44dp" android:minWidth="0dp" android:text="‹" android:textSize="28sp"/><TextView style="@style/TextAppearance.Mpos.Title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:text="Quản lý ca" /></LinearLayout>
    <TextView android:id="@+id/txtShiftStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/badge_blue" android:padding="14dp" android:textColor="@color/blue_primary_dark" android:textSize="16sp" />
    <EditText android:id="@+id/inputShiftCash" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="16dp" android:background="@drawable/input_background" android:hint="Tiền đầu/cuối ca" android:inputType="number" android:paddingHorizontal="16dp"/>
    <EditText android:id="@+id/inputHandoverNote" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="10dp" android:background="@drawable/input_background" android:hint="Ghi chú bàn giao" android:inputType="text" android:paddingHorizontal="16dp"/>
    <Button android:id="@+id/btnOpenShift" style="@style/Widget.Mpos.Button.Primary" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="20dp" android:text="Mở ca" />
    <Button android:id="@+id/btnCloseShift" style="@style/Widget.Mpos.Button.Outline" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="8dp" android:text="Đóng ca" />
    <Button android:id="@+id/btnShiftReport" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="48dp" android:text="Xem báo cáo ca" />
</LinearLayout>
