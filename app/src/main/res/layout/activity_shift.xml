<?xml version="1.0" encoding="utf-8"?>
<!--
    SHIFT MANAGEMENT — Quầy mPOS Pro
    Two-state UI: Open shift / Close shift.
    White AppBar (unified), design tokens throughout.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingBottom="64dp">

        <!-- ══ WHITE APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Quản lý ca làm việc"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Dark Shift Status Card -->
                <LinearLayout
                    android:id="@+id/cardShiftStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_dark_card"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Revenue + Status badge row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DOANH THU CA"
                                android:textColor="#64748B"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/txtShiftRevenue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="#FFFFFF"
                                android:textSize="24sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/txtShiftStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/badge_warning"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:text="Chưa mở ca"
                            android:textColor="#EAB308"
                            android:textSize="12sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtShiftOpenTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="#94A3B8"
                        android:textSize="13sp"/>
                </LinearLayout>

                <!-- Cash Input -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="TIỀN MẶT ĐẦU / CUỐI CA"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <EditText
                    android:id="@+id/inputShiftCash"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:hint="Nhập số tiền (VNĐ)"
                    android:inputType="number"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"
                    android:elevation="1dp"/>

                <!-- Handover Notes -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="GHI CHÚ BÀN GIAO"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <EditText
                    android:id="@+id/inputHandoverNote"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:gravity="top"
                    android:hint="Ghi chú bàn giao ca (tùy chọn)"
                    android:inputType="textMultiLine"
                    android:padding="14dp"
                    android:textColor="#1C2333"
                    android:textColorHint="#94A3B8"
                    android:elevation="1dp"/>

                <!-- Action Buttons -->
                <LinearLayout
                    android:id="@+id/btnOpenShift"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:background="@drawable/bg_pos_cat_active"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="▶  Mở ca làm việc"
                        android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnCloseShift"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="■  Đóng ca"
                        android:textColor="#EF4444" android:textSize="15sp" android:textStyle="bold"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/btnShiftReport"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:text="Xem báo cáo ca →"
                    android:textColor="#1A73E8"
                    android:textSize="14sp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>

    <!-- Staff Bottom Nav (Settings active) -->
    <include
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        layout="@layout/include_bottom_nav_settings"/>

</FrameLayout>
