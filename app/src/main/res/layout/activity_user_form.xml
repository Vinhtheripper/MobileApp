<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/app_background" android:fitsSystemWindows="true" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_top_bar" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:clickable="true" android:focusable="true" android:gravity="center" android:text="←" android:textColor="@color/surface" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="Thông tin tài khoản" android:textColor="@color/surface" android:textSize="15sp" android:textStyle="bold" />
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_surface_card" android:orientation="vertical" android:padding="14dp">
                <EditText android:id="@+id/inputFullName" android:layout_width="match_parent" android:layout_height="50dp" android:background="@drawable/bg_field_soft" android:hint="Họ tên" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <EditText android:id="@+id/inputUsername" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" android:hint="Tên đăng nhập" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <EditText android:id="@+id/inputPassword" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" android:hint="Mật khẩu mới (bỏ trống nếu không đổi)" android:inputType="textPassword" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <Spinner android:id="@+id/spinnerRole" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" />
                <EditText android:id="@+id/inputPhone" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" android:hint="Số điện thoại" android:inputType="phone" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <EditText android:id="@+id/inputEmail" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" android:hint="Email" android:inputType="textEmailAddress" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <EditText android:id="@+id/inputPosition" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_field_soft" android:hint="Chức danh" android:paddingHorizontal="14dp" android:textSize="13sp" />
                <CheckBox android:id="@+id/checkActive" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:checked="true" android:text="Tài khoản đang hoạt động" android:textColor="@color/text_primary" />
            </LinearLayout>
            <Button android:id="@+id/btnSaveUser" style="@style/Widget.Mpos.Button.Primary" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="16dp" android:text="Lưu tài khoản" />
            <Button android:id="@+id/btnDeleteUser" style="@style/Widget.Mpos.Button.Ghost" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="8dp" android:text="Khóa tài khoản" android:textColor="@color/status_error" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
