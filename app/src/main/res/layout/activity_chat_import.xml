<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/app_background" android:fitsSystemWindows="true" android:orientation="vertical">
    <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:background="@drawable/bg_top_bar" android:gravity="center_vertical" android:orientation="horizontal" android:paddingHorizontal="12dp">
        <TextView android:id="@+id/btnBack" android:layout_width="40dp" android:layout_height="40dp" android:clickable="true" android:focusable="true" android:gravity="center" android:text="←" android:textColor="@color/surface" android:textSize="18sp" android:textStyle="bold" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_weight="1" android:text="Nhập đơn từ chat" android:textColor="@color/surface" android:textSize="15sp" android:textStyle="bold" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
        <EditText android:id="@+id/inputChatOrder" android:layout_width="match_parent" android:layout_height="140dp" android:background="@drawable/bg_field_soft" android:gravity="top|start" android:hint="VD: Lan Nguyen, 0912345678, 2 bánh quy, giao Q1 HCM" android:inputType="textMultiLine" android:padding="14dp" android:textSize="13sp" />
        <TextView android:id="@+id/txtParsedPreview" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/bg_surface_card" android:padding="14dp" android:text="Thông tin parse sẽ hiển thị tại đây" android:textColor="@color/text_primary" android:textSize="14sp" />
        <Button android:id="@+id/btnParseChat" style="@style/Widget.Mpos.Button.Outline" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="12dp" android:text="Xem trước" />
        <Button android:id="@+id/btnCreateDraftOrder" style="@style/Widget.Mpos.Button.Primary" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="8dp" android:text="Tạo đơn nháp" />
    </LinearLayout>
</LinearLayout>
