<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F8FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- AppBar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1C2333"
            android:elevation="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="←"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Nhập / Điều chỉnh kho"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Product Selector Label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TÌM SẢN PHẨM (SKU / BARCODE)"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView android:layout_width="24dp" android:layout_height="24dp"
                        android:gravity="center" android:text="📦" android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/inputAdjustSku"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="SKU hoặc barcode sản phẩm"
                        android:inputType="text"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Quantity -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="TỒN KHO MỚI"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_white_12"
                    android:elevation="1dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView android:layout_width="24dp" android:layout_height="24dp"
                        android:gravity="center" android:text="🔢" android:textSize="16sp"/>

                    <EditText
                        android:id="@+id/inputAdjustStock"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:background="@null"
                        android:hint="Số lượng tồn kho mới"
                        android:inputType="number"
                        android:textColor="#1C2333"
                        android:textColorHint="#94A3B8"
                        android:textSize="14sp"/>
                </LinearLayout>

                <!-- Confirm Button -->
                <LinearLayout
                    android:id="@+id/btnAdjustStock"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="28dp"
                    android:background="@drawable/bg_pos_cat_active"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="✓  Lưu điều chỉnh"
                        android:textColor="#FFFFFF" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
