<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blue_navy"
        android:elevation="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_logo_bg"
            android:scaleType="centerInside"
            android:contentDescription="Quầy"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Tạo cửa hàng"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <!-- Welcome text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Chào mừng!"
                android:textColor="#1C2333"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hãy đặt tên cho cửa hàng của bạn để bắt đầu"
                android:textColor="#64748B"
                android:textSize="14sp"
                android:layout_marginBottom="24dp"/>

            <!-- Logo picker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <FrameLayout
                    android:id="@+id/btnPickLogo"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_shop_logo_circle"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/imgShopLogo"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        android:contentDescription="Logo cửa hàng"/>

                    <LinearLayout
                        android:id="@+id/layoutLogoPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">
                        <ImageView
                            android:layout_width="28dp"
                            android:layout_height="28dp"
                            android:src="@drawable/ic_camera"
                            android:scaleType="fitCenter"
                            android:contentDescription="@null"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Logo"
                            android:textColor="#64748B"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chọn logo cửa hàng"
                    android:textColor="#3B82F6"
                    android:textSize="13sp"/>
            </LinearLayout>

            <!-- Form card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_register_card"
                android:elevation="3dp"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="24dp"
                android:paddingBottom="20dp">

                <!-- Shop name -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TÊN CỬA HÀNG *"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <EditText
                    android:id="@+id/inputShopName"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_register"
                    android:hint="VD: Cà phê Sáng Tạo"
                    android:inputType="textCapWords"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"/>

                <!-- Address -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="ĐỊA CHỈ"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <EditText
                    android:id="@+id/inputShopAddress"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_register"
                    android:hint="VD: 123 Nguyễn Huệ, Q.1, TP.HCM"
                    android:inputType="textCapSentences"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"/>

                <!-- Phone -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="SỐ ĐIỆN THOẠI CỬA HÀNG"
                    android:textColor="#64748B"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"/>

                <EditText
                    android:id="@+id/inputShopPhone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_register"
                    android:hint="VD: 0900 123 456"
                    android:inputType="phone"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:textColor="#0F172A"
                    android:textColorHint="#9CA3AF"
                    android:textSize="15sp"/>

            </LinearLayout>

            <!-- Error message -->
            <TextView
                android:id="@+id/txtCreateShopError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/badge_error"
                android:padding="12dp"
                android:textColor="@color/status_error"
                android:visibility="gone"/>

            <!-- Create button -->
            <Button
                android:id="@+id/btnCreateShop"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_register_btn"
                android:elevation="4dp"
                android:stateListAnimator="@null"
                android:text="Tạo cửa hàng"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
