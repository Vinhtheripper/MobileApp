<?xml version="1.0" encoding="utf-8"?>
<!--
    INVENTORY HISTORY — Quầy mPOS Pro
    Transaction history: in/out/adjustment movements per product.
    White AppBar, filter chips, RecyclerView.
    Built from 2-line stub. Replaces ListView.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ WHITE APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="16dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lịch sử kho"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtProductName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ SUMMARY ROW ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:orientation="horizontal"
            android:paddingStart="@dimen/screen_gutter"
            android:paddingEnd="@dimen/screen_gutter"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">

            <!-- In -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/txtTotalIn"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/status_success"
                    android:textSize="20sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Nhập kho" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/border"/>

            <!-- Out -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/txtTotalOut"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/status_error"
                    android:textSize="20sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Xuất kho" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_marginTop="2dp"/>
            </LinearLayout>

            <View android:layout_width="1dp" android:layout_height="match_parent"
                android:background="@color/border"/>

            <!-- Current stock -->
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                <TextView android:id="@+id/txtCurrentStock"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="0" android:textColor="@color/blue_primary"
                    android:textSize="20sp" android:textStyle="bold"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tồn kho" android:textColor="@color/text_secondary"
                    android:textSize="11sp" android:layout_marginTop="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- ══ FILTER CHIPS ══ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@color/surface"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:scrollbars="none">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView android:id="@+id/chipAll"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat_active"
                    android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:text="Tất cả" android:textColor="#FFFFFF" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/chipIn"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:text="Nhập kho" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/chipOut"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:text="Xuất kho" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>

                <TextView android:id="@+id/chipAdjust"
                    android:layout_width="wrap_content" android:layout_height="30dp"
                    android:background="@drawable/bg_pos_cat"
                    android:gravity="center" android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:text="Điều chỉnh" android:textColor="@color/text_secondary" android:textSize="12sp"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- Divider -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/border"/>

        <!-- ══ HISTORY LIST — RecyclerView replaces ListView ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listInventoryHistory"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="@dimen/screen_gutter"
            android:paddingEnd="@dimen/screen_gutter"
            android:paddingTop="8dp"
            android:paddingBottom="16dp"
            android:overScrollMode="never"/>

    </LinearLayout>
</FrameLayout>
