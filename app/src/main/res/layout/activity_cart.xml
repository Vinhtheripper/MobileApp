<?xml version="1.0" encoding="utf-8"?>
<!--
    CART SCREEN — Quầy mPOS Pro
    Design: white AppBar, RecyclerView items, summary, checkout button.
    No emoji icons. No dark AppBar.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ══ WHITE APPBAR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/bg_appbar_white"
            android:elevation="2dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_back"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/txtCartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giỏ hàng"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Clear cart — delete icon, not emoji -->
            <ImageView
                android:id="@+id/btnClearCart"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_delete"
                android:tint="@color/status_error"
                android:scaleType="center"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Xóa giỏ hàng"/>
        </LinearLayout>

        <!-- ══ FREESHIP PROGRESS BANNER ══ -->
        <LinearLayout
            android:id="@+id/layoutFreeshipBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#EEF4FF"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="6dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🚚 Mua thêm để được miễn phí vận chuyển"
                    android:textColor="#1E3472"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/txtFreeshipRemain"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Còn 230K"
                    android:textColor="#2875FB"
                    android:textSize="12sp"
                    android:textStyle="bold"/>
            </LinearLayout>
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#D1E3FF">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:orientation="horizontal">
                    <View
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="6"
                        android:background="#2875FB"/>
                    <View
                        android:layout_width="0dp"
                        android:layout_height="4dp"
                        android:layout_weight="4"/>
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ══ CART ITEM LIST — RecyclerView ══ -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listCart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="@dimen/screen_gutter"
            android:paddingEnd="@dimen/screen_gutter"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:overScrollMode="never"/>

        <!-- ══ SUMMARY + CHECKOUT PANEL ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:elevation="8dp"
            android:orientation="vertical"
            android:paddingStart="@dimen/screen_gutter"
            android:paddingEnd="@dimen/screen_gutter"
            android:paddingTop="14dp"
            android:paddingBottom="24dp">

            <!-- Dark summary block -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_hero_flat_blue"
                android:orientation="vertical"
                android:padding="14dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CHI TIẾT THANH TOÁN"
                    android:textColor="#C3D7FC"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Subtotal row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Tạm tính" android:textColor="#C3D7FC" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtSubtotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Tax row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="Thuế VAT" android:textColor="#C3D7FC" android:textSize="13sp"/>
                    <TextView android:id="@+id/txtTax"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#3A5599" android:layout_marginBottom="10dp"/>

                <!-- Total row -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                        android:text="TỔNG THANH TOÁN" android:textColor="#FFFFFF"
                        android:textSize="13sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtCartTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Checkout Button -->
            <Button
                android:id="@+id/btnCartCheckout"
                style="@style/Widget.Mpos.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Thanh toán →"/>

        </LinearLayout>
    </LinearLayout>
</FrameLayout>